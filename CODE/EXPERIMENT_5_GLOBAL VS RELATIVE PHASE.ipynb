   "outputs": [],
   "source": [
    "theta = np.pi/2\n",
    "phi_values = [0, np.pi/2, np.pi, 3*np.pi/2]\n",
    "\n",
    "for phi in phi_values:\n",
    "    alpha = np.cos(theta/2)\n",
    "    beta = np.exp(1j*phi)*np.sin(theta/2)\n",
    "\n",
    "    P1 = abs(beta)**2\n",
    "    print(\"\\nRelative phase:\",phi)\n",
    "    print(\"P(1):\",P1)"
   ]
  }
